# ---------------------------------------------------------------------------
# Build-time settings (used by scripts/build.sh and scripts/push.sh).
# ---------------------------------------------------------------------------
# Base n8n image to FROM. Default uses the community-maintained Chinese
# localization (ghcr.io/deluxebear/n8n:chs). To use the official English-only
# image instead, set BASE_N8N_IMAGE=n8nio/n8n:latest or n8nio/n8n:<version>.
BASE_N8N_IMAGE=ghcr.io/deluxebear/n8n:chs
# Base image name for the customer image; final image will be
# <REGISTRY>/<IMAGE_NAME>-<client>:<tag>.
IMAGE_NAME=n8n


# ---------------------------------------------------------------------------
# Runtime settings for deploy/docker-compose.yml (filled in by the customer).
# ---------------------------------------------------------------------------

# The customer image to pull. After you push, set this to the full reference.
# Example: registry.example.com/n8n/n8n-client-a:1.0
N8N_IMAGE=

# --- Owner bootstrap. ---
# Email the customer uses to log in to n8n.
OWNER_EMAIL=admin@client.local
# Bcrypt hash of the password. Generate with:
#   docker run --rm httpd:2.4 htpasswd -nbBC 12 '' 'YOUR_PASSWORD' | tr -d ':\n' | sed 's/^\$2y\$/\$2b\$/'
# The hash MUST start with $2b$ (n8n requires $2b$ specifically). The command
# above converts htpasswd's $2y$ output to $2b$.
OWNER_PASSWORD_HASH=
OWNER_FIRST_NAME=Admin
OWNER_LAST_NAME=Client

# --- Public URL. Set if the customer accesses n8n via a domain / proxy. ---
N8N_EDITOR_BASE_URL=
N8N_WEBHOOK_URL=
N8N_PORT=5678

# --- Execution mode. "regular" for single-node, "queue" requires redis. ---
EXECUTIONS_MODE=regular